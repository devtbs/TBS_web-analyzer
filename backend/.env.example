# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tbs_marketing

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT Secret
SECRET_KEY=your-super-secret-key-change-this-in-production

# API Keys (Optional - for enhanced AI analysis)
OPENAI_API_KEY=your-openai-api-key
# AI-deck photos are generated by Supermachine (dev.supermachine.art)
SUPERMACHINE_API_KEY=your-supermachine-api-key
SUPERMACHINE_MODEL=Supermachine NextGen
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=
DEEPSEEK_API_KEY=
SERPAPI_KEY=
FIRECRAWL_API_KEY=
SERANKING_API_KEY=

# App Settings
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
